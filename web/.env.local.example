# ── Backend ──────────────────────────────────────────────────────────────────
# URL de ton API FastAPI (Railway, Render, local)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Créer un projet sur https://console.cloud.google.com
# APIs & Services > Credentials > OAuth 2.0 Client IDs
# Ajouter origins autorisés: http://localhost:3000, https://domely.app
# Ajouter redirect URIs: http://localhost:3000, https://domely.app
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# La même valeur côté backend (FastAPI vérifie l'audience du token)
GOOGLE_CLIENT_ID=

# ── Stripe ───────────────────────────────────────────────────────────────────
# Clés disponibles sur https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Secret webhook — généré dans Stripe Dashboard > Webhooks
# URL à enregistrer : https://domely.app/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — créer les prix dans Stripe Dashboard > Products
# Plan Pro — 29$/mois
STRIPE_PRICE_PRO_MONTHLY=price_...
# Plan Pro — 23$/mois (annuel)
STRIPE_PRICE_PRO_YEARLY=price_...
# Plan Team — 79$/mois
STRIPE_PRICE_TEAM_MONTHLY=price_...
# Plan Team — 63$/mois (annuel)
STRIPE_PRICE_TEAM_YEARLY=price_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Clé disponible sur https://resend.com/api-keys
# Domaine à vérifier : domely.app
RESEND_API_KEY=re_...

# ── Internal service key ──────────────────────────────────────────────────────
# Clé secrète partagée entre Next.js et FastAPI pour les appels internes.
# Mets la MÊME valeur dans les deux environnements (ex: openssl rand -hex 32)
INTERNAL_API_KEY=changeme_generate_with_openssl_rand_hex_32
